// =============================================================================
// Development-specific Syncthing ignore patterns
// Include default patterns first, then add dev-specific ones
// =============================================================================
#include .stignore.default

// =============================================================================
// IDE and editor project files
// =============================================================================
(?d)**/.idea
(?d)**/.vscode
(?d)**/.fleet
(?d)**/.project
(?d)**/.classpath
(?d)**/.settings
(?d)**/*.sublime-project
(?d)**/*.sublime-workspace

// =============================================================================
// Build artifacts and compiled output
// =============================================================================

// Generic build directories
(?d)**/build
(?d)**/.build
(?d)**/dist
(?d)**/out
(?d)**/output
(?d)**/bin
(?d)**/obj

// Compiled objects and libraries
(?d)**/*.o
(?d)**/*.a
(?d)**/*.so
(?d)**/*.so.*
(?d)**/*.dylib
(?d)**/*.dll
(?d)**/*.lib
(?d)**/*.lo
(?d)**/*.slo
(?d)**/*.lai
(?d)**/*.la
(?d)**/*.obj
(?d)**/*.exe
(?d)**/*.exe~
(?d)**/*.pdb
(?d)**/*.ilk
(?d)**/*.gch
(?d)**/*.pch
(?d)**/*.dwo
(?d)**/*.d
(?d)**/*.class

// CMake
(?d)**/CMakeFiles
(?d)**/CMakeCache.txt
(?d)**/cmake_install.cmake
(?d)**/compile_commands.json

// =============================================================================
// Language-specific dependencies and caches
// =============================================================================

// Node.js / Frontend
(?d)**/node_modules
(?d)**/.next
(?d)**/.nuxt
(?d)**/.output
(?d)**/.turbo
(?d)**/.parcel-cache
(?d)**/.svelte-kit
(?d)**/.astro
(?d)**/.docusaurus
(?d)**/.vite
(?d)**/jspm_packages
(?d)**/bower_components
(?d)**/web_modules
(?d)**/.eslintcache
(?d)**/.stylelintcache
(?d)**/.pnpm-store
(?d)**/.yarn/*
(?d)**/.bun

// Go
(?d)**/vendor

// Rust
(?d)**/target

// Python
(?d)**/.venv
(?d)**/venv
(?d)**/__pycache__
(?d)**/*.pyc
(?d)**/*.pyo
(?d)**/*.pyz
(?d)**/.mypy_cache
(?d)**/.pytest_cache
(?d)**/.ruff_cache
(?d)**/.hypothesis
(?d)**/.tox
(?d)**/.nox
(?d)**/.coverage
(?d)**/.eggs
(?d)**/*.egg-info
(?d)**/.pybuilder
(?d)**/pip-log.txt

// Java / Kotlin / Gradle / Maven
(?d)**/.gradle
(?d)**/.m2
(?d)**/*.jar
(?d)**/*.war
(?d)**/*.ear
(?d)**/*.nar
(?d)**/hs_err_pid*
(?d)**/replay_pid*
(?d)**/.mtj.tmp

// Ruby
(?d)**/.bundle
(?d)**/vendor/bundle

// Dart / Flutter
(?d)**/.dart_tool
(?d)**/.flutter-plugins
(?d)**/.flutter-plugins-dependencies
(?d)**/.pub-cache

// Swift / Xcode
(?d)**/xcuserdata
(?d)**/*.dSYM
(?d)**/*.dSYM.zip
(?d)**/*.ipa

// C# / .NET
(?d)**/packages
(?d)**/TestResults

// =============================================================================
// Infrastructure / DevOps
// =============================================================================

// Terraform / OpenTofu
(?d)**/.terraform
(?d)**/*.tfstate
(?d)**/*.tfstate.*
(?d)**/.terraform.tfstate.lock.info

// Docker
(?d)**/.docker

// Vagrant
(?d)**/.vagrant

// =============================================================================
// Testing and coverage
// =============================================================================
(?d)**/coverage
(?d)**/.nyc_output
(?d)**/htmlcov
(?d)**/*.lcov
(?d)**/*.coverprofile

// =============================================================================
// AI / LLM tools local state
// =============================================================================
(?d)**/.claude
(?d)**/.codex
(?d)**/.copilot

// =============================================================================
// Logs, PIDs, and runtime files
// =============================================================================
(?d)**/*.log
(?d)**/*.tmp
(?d)**/*.temp
(?d)**/*.bak
(?d)**/*.old
(?d)**/*.orig
(?d)**/*.part
(?d)**/*.crdownload
(?d)**/*.stackdump
(?d)**/*.pid
(?d)**/*.pid.lock
(?d)**/*.sock

// SQLite journals and WAL
(?d)**/*.sqlite-journal
(?d)**/*.sqlite-wal
(?d)**/*.sqlite-shm

// =============================================================================
// Archives (large, typically regenerable)
// =============================================================================
(?d)**/*.7z
(?d)**/*.rar
(?d)**/*.zip
(?d)**/*.gz
(?d)**/*.tgz
(?d)**/*.bz2
(?d)**/*.xz
(?d)**/*.zst
(?d)**/*.lzma
(?d)**/*.tar
(?d)**/*.iso
(?d)**/*.dmg
(?d)**/*.deb
(?d)**/*.rpm
(?d)**/*.msi
(?d)**/*.cab
(?d)**/*.gem
(?d)**/*.egg
