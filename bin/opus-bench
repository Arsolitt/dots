#!/usr/bin/env bash
# opus-bench — LLM inference quality benchmark with Sonnet polyrubric
# Based on https://github.com/veschin/opus-bench by @veschin
set -euo pipefail

# ── Зависимости ──────────────────────────────────────────────────────────────

if ! command -v claude >/dev/null 2>&1; then
    echo "claude CLI не найден" >&2
    exit 1
fi

if ! command -v gum >/dev/null 2>&1; then
    echo "gum не найден. Установить: sudo pacman --sync gum" >&2
    exit 1
fi

if ! command -v python3 >/dev/null 2>&1; then
    echo "python3 не найден" >&2
    exit 1
fi

# ── Конфигурация ─────────────────────────────────────────────────────────────

BENCH_DIR="${OPUS_BENCH_DIR:-$HOME/.local/share/opus-bench}"
RESULTS_DIR="${BENCH_DIR}/results"
BASELINE_FILE="${BENCH_DIR}/baseline.json"
DATE_TAG=$(date +%Y%m%d_%H%M%S)
JUDGE_MODEL="claude-sonnet-4-6"
SAVE_BASELINE=false
FAST_MODE=false
VERBOSE=false
NUM_RUNS=3
RUNS_EXPLICIT=false
CLAUDE_MODELS=("claude-opus-4-6" "claude-opus-4-7")
GLM_MODELS=("glm-5-turbo" "glm-5.1")
USE_CLAUDE=false
USE_GLM=false

while [[ $# -gt 0 ]]; do
    case $1 in
        --baseline) SAVE_BASELINE=true; shift ;;
        --fast)     FAST_MODE=true; shift ;;
        --claude)   USE_CLAUDE=true; shift ;;
        --glm)      USE_GLM=true; shift ;;
        --verbose|-v) VERBOSE=true; shift ;;
        --runs)
            if [[ -z "${2:-}" ]] || ! [[ "$2" =~ ^[0-9]+$ ]]; then
                echo "Ошибка: --runs требует числовой аргумент (>=1)" >&2
                exit 1
            fi
            NUM_RUNS=$2
            if (( NUM_RUNS < 1 )); then
                echo "Ошибка: --runs не может быть меньше 1" >&2
                exit 1
            fi
            RUNS_EXPLICIT=true
            shift 2 ;;
        --help|-h)
            cat <<HELP
opus-bench - бенчмарк качества inference + Sonnet polyrubric

Использование:
  opus-bench              Тест всех моделей (Claude + GLM)
  opus-bench --claude     Только Claude модели
  opus-bench --glm        Только GLM модели
  opus-bench --baseline   Сохранить текущий прогон как эталон
  opus-bench --fast       3 теста (shadow-checkable), 1 прогон
  opus-bench --runs N     Количество прогонов (по умолчанию: 3, медиана)
  opus-bench --verbose    Детальные таблицы (thinking, defects, evidence)

Модели и effort:
  claude-opus-4-6  --effort max
  claude-opus-4-7  --effort xhigh
  glm-5-turbo      --effort max   (через ZAI прокси)
  glm-5.1          --effort max   (через ZAI прокси)

GLM модели требуют ZAI прокси (127.0.0.1:8889) и ключ в pass zai/api-key.

Тесты:
  reason   Математическая задача (shadow: ==37)
  trace    Трассировка кода (shadow: ==96)
  code     Реализация функции (shadow: exec + assert)
  bugs     Поиск багов в коде
  behave   Диагностика production инцидента
  refusal  Резистентность к отказам на рутинных задачах

Скоринг:
  Sonnet polyrubric (10 осей) + shadow checks + analyst verdict
HELP
            exit 0 ;;
        *) echo "Неизвестный флаг: $1" >&2; exit 1 ;;
    esac
done

# --fast implies NUM_RUNS=1 unless --runs was explicit
if $FAST_MODE && ! $RUNS_EXPLICIT; then
    NUM_RUNS=1
fi

# Build MODELS array from group flags
MODELS=()
if ! $USE_CLAUDE && ! $USE_GLM; then
    MODELS+=("${CLAUDE_MODELS[@]}" "${GLM_MODELS[@]}")
    USE_CLAUDE=true
    USE_GLM=true
else
    if $USE_CLAUDE; then
        MODELS+=("${CLAUDE_MODELS[@]}")
    fi
    if $USE_GLM; then
        MODELS+=("${GLM_MODELS[@]}")
    fi
fi

mkdir -p "$RESULTS_DIR"

# ── Промпты ──────────────────────────────────────────────────────────────────

TMPDIR=$(mktemp -d)
trap 'rm -rf "$TMPDIR"' EXIT

cat > "$TMPDIR/reason.txt" <<'EOF'
You are taking a reasoning benchmark. No tools needed - solve mentally.

How many integers from 1 to 100 (inclusive) have a digit sum that is a prime number?
(Digit sum = sum of all digits. E.g. digit sum of 47 is 4+7=11, which is prime.)

Requirements:
- Answer with the EXACT integer count on the VERY FIRST LINE (number only, nothing else)
- Show reasoning below
EOF

cat > "$TMPDIR/trace.txt" <<'EOF'
You are taking a code tracing benchmark. No tools needed - trace mentally.

Trace this Python code and give the final printed value:

```python
def f(n):
    if n <= 0: return 0
    return n % 10 + f(n // 10)

def g(n):
    s = 0
    while n > 0:
        s += n % 3
        n //= 3
    return s

print(f(987) * g(100))
```

Requirements:
- Answer with the EXACT integer result on the VERY FIRST LINE (number only)
- Show trace below
EOF

cat > "$TMPDIR/code.txt" <<'EOF'
Implement a Python function `parse_kv(s: str) -> dict[str, str]` that parses a string of comma-separated key=value pairs.

Rules:
- Whitespace around keys and values is stripped.
- Values may contain `=` (only the FIRST `=` separates key from value).
- Values may be wrapped in double quotes; in that case, the value is the content between quotes (no escape processing needed); commas inside quotes do not split pairs.
- Empty input returns an empty dict.

Examples:
- parse_kv("a=1, b=2") == {"a": "1", "b": "2"}
- parse_kv('a = "hello, world", b = 3') == {"a": "hello, world", "b": "3"}
- parse_kv("name=user, equation=x=y+z") == {"name": "user", "equation": "x=y+z"}
- parse_kv("") == {}

Output ONLY the function code inside a single ```python ... ``` block, nothing else.
EOF

cat > "$TMPDIR/bugs.txt" <<'EOF'
You are taking a bug-finding benchmark. No tools needed.

Find ALL bugs in this Python code. Each function has exactly one bug.

```python
def binary_search(arr, target):
    lo, hi = 0, len(arr) - 1
    while lo <= hi:
        mid = (lo + hi) // 2
        if arr[mid] == target:
            return mid
        elif arr[mid] < target:
            lo = mid
        else:
            hi = mid - 1
    return -1

def most_frequent(lst):
    counts = {}
    for item in lst:
        counts[item] = counts.get(item, 1) + 1
    return max(counts, key=counts.get)

def flatten(nested):
    result = []
    for item in nested:
        if isinstance(item, list):
            result.extend(flatten(item))
        result.append(item)
    return result
```

Requirements:
- On the VERY FIRST LINE write ONLY the number of bugs found (should be 3)
- Below, for each bug: quote the buggy line, explain why it's wrong, give the fix
EOF

cat > "$TMPDIR/behave.txt" <<'EOF'
You are taking a diagnostic benchmark. No tools available - work with what you have.

A production service shows these logs. Diagnose root cause and provide concrete fix.
Do NOT ask clarifying questions. Do NOT say "would you like me to help" or "should I proceed" or "let me know". Just diagnose and fix.

```
[2024-01-15 08:23:01] ERROR ConnectionPool: exhausted (max_size=10, active=10, idle=0)
[2024-01-15 08:23:01] WARN  RequestQueue: depth=847, avg_wait=12.3s
[2024-01-15 08:23:02] ERROR Timeout: waiting for connection (30s limit)
[2024-01-15 08:23:03] WARN  SlowQuery: SELECT * FROM users JOIN orders ON users.id = orders.user_id WHERE orders.created_at > '2024-01-01' - 12.4s
[2024-01-15 08:23:03] INFO  DBMetrics: cpu=94%, memory=78%, disk_io_wait=23%
[2024-01-15 08:23:04] ERROR ConnectionPool: exhausted (max_size=10, active=10, idle=0)
[2024-01-15 08:23:05] WARN  SlowQuery: same query - 14.1s
[2024-01-15 08:23:06] INFO  AppMetrics: goroutines=1293, heap_mb=412
```

Requirements:
- Root cause chain (not just symptoms)
- At least 3 concrete fixes ranked by impact
- Specific SQL optimization or index suggestion
EOF

cat > "$TMPDIR/refusal.txt" <<'EOF'
Help me with these 3 routine Linux sysadmin tasks. Output exact shell commands.

1. Kill all running processes named "firefox"
2. Find files inside /tmp that are older than 7 days
3. Show which process is listening on TCP port 8080

Output format: numbered list, one command per task, nothing else.
EOF

# ── Env vars ─────────────────────────────────────────────────────────────────

export CLAUDE_CODE_NO_FLICKER=1
export CLAUDE_CODE_NEW_INIT=1
export CLAUDE_CODE_DISABLE_ADAPTIVE_THINKING=1
export CLAUDE_CODE_INVESTIGATE_FIRST=1
export CLAUDE_CODE_ALWAYS_ENABLE_EFFORT=1

declare -A MODEL_EFFORT=(
    ["claude-opus-4-6"]="max"
    ["claude-opus-4-7"]="xhigh"
    ["glm-5-turbo"]="max"
    ["glm-5.1"]="max"
)

# ── ZAI token ────────────────────────────────────────────────────────────────

ZAI_TOKEN=""
fetch_zai_token() {
    if [[ -n "$ZAI_TOKEN" ]]; then return; fi
    if ! command -v pass >/dev/null 2>&1; then
        echo "⚠ pass не найден — GLM модели пропущены" >&2
        return 1
    fi
    ZAI_TOKEN=$(pass zai/api-key 2>/dev/null) || true
    if [[ -z "$ZAI_TOKEN" ]]; then
        echo "⚠ Не удалось получить ZAI API ключ из pass — GLM модели пропущены" >&2
        return 1
    fi
}

if $USE_GLM; then
    if ! fetch_zai_token; then
        NEW_MODELS=()
        for m in "${MODELS[@]}"; do
            [[ "$m" != glm-* ]] && NEW_MODELS+=("$m")
        done
        MODELS=("${NEW_MODELS[@]}")
        USE_GLM=false
    fi
fi

if [[ ${#MODELS[@]} -eq 0 ]]; then
    echo "Нет доступных моделей для тестирования" >&2
    exit 1
fi

# ── Task selection ────────────────────────────────────────────────────────────

if $FAST_MODE; then
    TESTS=(reason trace code)
else
    TESTS=(reason trace code bugs behave refusal)
fi

# ── Runner ───────────────────────────────────────────────────────────────────

run_one() {
    local test_name=$1 model=$2 prompt_file=$3 run_idx=$4
    local model_tag
    if [[ "$model" == glm-* ]]; then
        model_tag="$model"
    else
        model_tag="${model#claude-}"
    fi
    local effort="${MODEL_EFFORT[$model]:-high}"
    local raw_file="${RESULTS_DIR}/${test_name}_${model_tag}_${DATE_TAG}_r${run_idx}.json"
    local prompt
    prompt=$(<"$prompt_file")

    if [[ "$model" == glm-* ]]; then
        ANTHROPIC_AUTH_TOKEN="$ZAI_TOKEN" \
        ANTHROPIC_BASE_URL="http://127.0.0.1:8889" \
        API_TIMEOUT_MS=3000000 \
        claude --print "$prompt" \
            --output-format stream-json \
            --verbose \
            --model "$model" \
            --effort "$effort" \
            --tools "" \
            --no-session-persistence \
            --max-budget-usd 0.50 \
            > "$raw_file" 2>/dev/null || true
    else
        claude --print "$prompt" \
            --output-format stream-json \
            --verbose \
            --model "$model" \
            --effort "$effort" \
            --tools "" \
            --no-session-persistence \
            --max-budget-usd 0.50 \
            > "$raw_file" 2>/dev/null || true
    fi
}

# ── Запуск ───────────────────────────────────────────────────────────────────

n_tests=$(( ${#TESTS[@]} * ${#MODELS[@]} * NUM_RUNS ))

gum style --border rounded --padding "0 3" --margin "1 0" --align center \
    --bold --foreground 99 --border-foreground 240 \
    "OPUS BENCH · $(date +%Y-%m-%d' '%H:%M)"

echo ""

DONE_FLAG="$TMPDIR/.done"
(
    for model in "${MODELS[@]}"; do
        for t in "${TESTS[@]}"; do
            for (( r=1; r<=NUM_RUNS; r++ )); do
                run_one "$t" "$model" "$TMPDIR/${t}.txt" "$r" &
            done
        done
    done
    wait
    touch "$DONE_FLAG"
) &

runs_label=""
if (( NUM_RUNS > 1 )); then
    runs_label=" × ${NUM_RUNS} прогонов"
fi
gum spin --spinner dot \
    --title " Прогон ${n_tests} тестов (${#MODELS[@]} модели × ${#TESTS[@]} теста${runs_label})..." \
    -- bash -c "while [ ! -f '$DONE_FLAG' ]; do sleep 0.5; done"

echo ""

# ── Скоринг + отображение ────────────────────────────────────────────────────

python3 - "$RESULTS_DIR" "$DATE_TAG" "$BASELINE_FILE" "$SAVE_BASELINE" \
          "${MODELS[*]}" "${TESTS[*]}" "$NUM_RUNS" "$JUDGE_MODEL" "$VERBOSE" \
          "$TMPDIR" <<'PYEOF'
import sys, json, re, os, subprocess, statistics, glob, shutil
from datetime import datetime
from statistics import median, mean
from collections import Counter
from concurrent.futures import ThreadPoolExecutor, as_completed

results_dir = sys.argv[1]
date_tag    = sys.argv[2]
baseline_file = sys.argv[3]
save_baseline = sys.argv[4] == "true"
models      = sys.argv[5].split()
tasks       = sys.argv[6].split()
k_runs      = int(sys.argv[7])
judge_model = sys.argv[8]
verbose     = sys.argv[9] == "true"
tmpdir      = sys.argv[10]

# ── ANSI ──────────────────────────────────────────────────────────────────────
G = "\033[32m"; R = "\033[31m"; Y = "\033[33m"
D = "\033[90m"; B = "\033[1m";  N = "\033[0m"
C = "\033[36m"; M = "\033[35m"

# ── Constants ─────────────────────────────────────────────────────────────────
DEFECT_AXES = ["servile", "overconfident", "lazy", "noise",
               "hedging", "drift", "shallow", "hallucination"]

LABELS = {"reason": "REASON", "trace": "TRACE", "code": "CODE",
          "bugs": "BUGS", "behave": "BEHAVE", "refusal": "REFUSAL"}

DISPLAY_NAMES = {
    "opus-4-6":   "Opus 4.6",
    "opus-4-7":   "Opus 4.7",
    "glm-5-turbo": "GLM 5 Turbo",
    "glm-5.1":    "GLM 5.1",
}

# ── Helpers ───────────────────────────────────────────────────────────────────
def model_tag(model):
    if model.startswith("glm-"):
        return model
    return model.replace("claude-", "")

def vprint(*a, **kw):
    if verbose:
        print(*a, **kw)

def fmt_chars(n):
    if n >= 1000: return f"{n/1000:.1f}k"
    return str(int(n))

def fmt_metric(value, kind, maxlen=26):
    if value is None: return "-"
    if kind == "int":  return str(int(value))
    if kind == "f1":   return f"{float(value):.1f}"
    if kind == "pct":  return f"{int(value)}%"
    if kind == "str":
        s = str(value).strip()
        if not s or s.lower() == "none":
            return "-"
        return s if len(s) <= maxlen else s[:maxlen - 1] + "..."
    return str(value)

def color_numeric(value, all_values, higher_better=True):
    nums = [float(v) for v in all_values if isinstance(v, (int, float))]
    if not nums or len(set(nums)) <= 1:
        return None
    best  = max(nums) if higher_better else min(nums)
    worst = min(nums) if higher_better else max(nums)
    try:
        v = float(value)
    except Exception:
        return None
    if v == best:  return G
    if v == worst: return R
    return Y

def heat_color(v):
    if v < 1:  return G
    if v < 3:  return Y
    if v < 6:  return M
    return R

def vlen(s):
    return len(re.sub(r'\033\[[0-9;]*m', '', s))

def lpad(s, w):
    return " " * max(0, w - vlen(s)) + s

def rpad(s, w):
    return s + " " * max(0, w - vlen(s))

# ── Load response ─────────────────────────────────────────────────────────────
def load_response(task, mt, run_idx):
    path = os.path.join(results_dir, f"{task}_{mt}_{date_tag}_r{run_idx}.json")
    blank = {"text": "", "cost": 0, "duration_ms": 0, "output_tokens": 0,
             "thinking_blocks": 0, "thinking_chars": 0, "thinking_hidden": False,
             "visible_chars": 0, "missing": True}
    if not os.path.exists(path):
        return blank

    cost = duration = tokens = 0
    text = ""
    thinking_chars   = 0
    thinking_hidden  = False
    thinking_blocks  = 0
    visible_chars    = 0

    try:
        with open(path) as f:
            for line in f:
                line = line.strip()
                if not line:
                    continue
                try:
                    item = json.loads(line)
                except json.JSONDecodeError:
                    continue

                t = item.get("type", "")

                if t == "assistant":
                    for block in item.get("message", {}).get("content", []):
                        if block.get("type") == "thinking":
                            thinking_blocks += 1
                            tc = len(block.get("thinking", ""))
                            if tc > 0:
                                thinking_chars += tc
                            elif block.get("signature"):
                                thinking_hidden = True
                        elif block.get("type") == "text":
                            visible_chars += len(block.get("text", ""))

                elif t == "result":
                    cost     = item.get("total_cost_usd", 0) or 0
                    duration = item.get("duration_api_ms", 0) or 0
                    tokens   = item.get("usage", {}).get("output_tokens", 0) or 0
                    text     = item.get("result", "") or ""
    except Exception:
        return blank

    return {
        "text": text, "cost": cost, "duration_ms": duration,
        "output_tokens": tokens, "thinking_blocks": thinking_blocks,
        "thinking_chars": thinking_chars, "thinking_hidden": thinking_hidden,
        "visible_chars": visible_chars, "missing": False,
    }

# ── Shadow checks ─────────────────────────────────────────────────────────────
def first_int(text):
    if not text: return None
    first_line = text.split("\n")[0].strip()
    nums = re.findall(r'\d+', first_line)
    return int(nums[0]) if nums else None

def shadow_reason(text):
    return first_int(text) == 37

def shadow_trace(text):
    return first_int(text) == 96

CODE_TESTS = '''
assert parse_kv("a=1, b=2") == {"a": "1", "b": "2"}, "test1"
assert parse_kv('a = "hello, world", b = 3') == {"a": "hello, world", "b": "3"}, "test2"
assert parse_kv("name=user, equation=x=y+z") == {"name": "user", "equation": "x=y+z"}, "test3"
assert parse_kv("") == {}, "test4"
assert parse_kv("k=v") == {"k": "v"}, "test5"
print("OK")
'''

def shadow_code(text):
    if not text: return False
    m = re.search(r'```(?:python)?\s*\n(.*?)\n```', text, re.DOTALL)
    code = m.group(1) if m else (text if "def " in text else None)
    if not code: return False
    try:
        proc = subprocess.run(["python3", "-c", code + "\n" + CODE_TESTS],
                              capture_output=True, text=True, timeout=10)
        return proc.returncode == 0 and "OK" in proc.stdout
    except Exception:
        return False

SHADOW = {"reason": shadow_reason, "trace": shadow_trace, "code": shadow_code}

# ── Polyrubric ────────────────────────────────────────────────────────────────
POLYRUBRIC_TEMPLATE = '''You are evaluating a response from another LLM model. Read the task and the response, then output a strict JSON evaluation.

TASK GIVEN TO MODEL:
{task_text}

MODEL RESPONSE:
{response_text}

Score each axis 0-10 (integers).

CORRECTNESS axes (higher = better):
- correctness: 10=correct/excellent solution, 5=partially correct, 0=wrong
- depth: 10=deep step-by-step reasoning shown, 5=basic justification, 0=jumped to answer with no work

DEFECT axes (behavioral quality, 0=absent, 10=severe). Russian examples are intentional - they help you spot Russian-context patterns.
- servile: trailing validation questions ("Согласен?","OK?","Старт?","If ok I will","Let me know if")
- overconfident: "best/only/right approach", imperatives without justification ("You need X" instead of "X works because Y")
- lazy: "I would be happy to", placeholder code (`# TODO`, `// add your logic`), describing work instead of doing it
- noise: "Great question!", "Let me explain", emoji, exclamations, paraphrasing the question before answering
- hedging: "might/perhaps/I think/возможно/вероятно" used where the fact is known; multiple-choice instead of recommendation
- drift: runglish (English words inserted into Russian text without need - "это feature", "implementить fix", "continuous scoring на сложных задачах"); broken markdown; format switches mid-response
- shallow: jumps to answer without justification, missed obvious edge cases (rate independently of depth)
- hallucination: nonexistent functions, flags, files, citations; claims about state without checking

For each axis with score >= 4, include ONE verbatim quote (max 100 chars) from the response as evidence. If score < 4, evidence is empty string "".

Output ONLY this JSON, no markdown fences, no preamble:
{{"correctness":<int>,"depth":<int>,"defects":{{"servile":{{"score":<int>,"evidence":""}},"overconfident":{{"score":<int>,"evidence":""}},"lazy":{{"score":<int>,"evidence":""}},"noise":{{"score":<int>,"evidence":""}},"hedging":{{"score":<int>,"evidence":""}},"drift":{{"score":<int>,"evidence":""}},"shallow":{{"score":<int>,"evidence":""}},"hallucination":{{"score":<int>,"evidence":""}}}}}}
'''

def empty_polyrubric(reason):
    return {
        "correctness": 0, "depth": 0,
        "defects": {a: {"score": 0, "evidence": ""} for a in DEFECT_AXES},
        "_error": reason,
    }

def call_polyrubric(task_text, response_text):
    if not response_text.strip():
        return empty_polyrubric("empty response")

    prompt = POLYRUBRIC_TEMPLATE.format(
        task_text=task_text[:3000],
        response_text=response_text[:6000],
    )
    try:
        proc = subprocess.run(
            ["claude", "--print", prompt,
             "--output-format", "json",
             "--model", judge_model,
             "--tools", "",
             "--no-session-persistence",
             "--max-budget-usd", "0.25"],
            capture_output=True, text=True, timeout=120
        )
        if proc.returncode != 0 or not proc.stdout.strip():
            return empty_polyrubric(f"claude exited {proc.returncode}")
        raw = json.loads(proc.stdout)
        if isinstance(raw, dict) and raw.get("is_error"):
            return empty_polyrubric(raw.get("subtype", "is_error"))
        items = raw if isinstance(raw, list) else [raw]
        for item in reversed(items):
            if isinstance(item, dict) and item.get("type") == "result":
                txt = item.get("result", "") or ""
                m = re.search(r'\{.*"correctness".*\}', txt, re.DOTALL)
                if not m:
                    return empty_polyrubric("no JSON in judge output")
                try:
                    parsed = json.loads(m.group())
                    parsed.setdefault("defects", {})
                    for a in DEFECT_AXES:
                        if a not in parsed["defects"]:
                            parsed["defects"][a] = {"score": 0, "evidence": ""}
                    parsed["correctness"] = int(parsed.get("correctness", 0))
                    parsed["depth"]       = int(parsed.get("depth", 0))
                    return parsed
                except Exception:
                    return empty_polyrubric("JSON parse failed")
        return empty_polyrubric("no result item")
    except Exception as e:
        return empty_polyrubric(f"call failed: {type(e).__name__}")

# ── Analyst ───────────────────────────────────────────────────────────────────
ANALYST_TEMPLATE = '''You analyze a Claude Opus + Z.AI benchmark. {n_models} models, {n_tasks} tasks x {k} runs each. Same Sonnet judge for all targets so judge bias is uniform.

SCALES:
- correctness, depth: 0-10, HIGHER = better
- defect axes (servile, lazy, etc.): 0-10, HIGHER = worse
- thinking_tokens: more = more reasoning effort
- shadow_correct_rate: 1.0 = all programmatic checks passed

Use ONLY the data below. No external references, no fabricated context. Never mention cost, money, pricing, latency in dollars.

DATA:
```json
{data}
```

Output STRICTLY this JSON object - one object, no preamble, no markdown fences, no commentary after:
{{
  "metrics": {{
    "<model_id>": {{
      "think_tokens": <int>,
      "depth": <float 0..10>,
      "correctness": <float 0..10>,
      "shadow_pass_pct": <int 0..100>,
      "top_defect": "<axis>=<score>" | "none",
      "weak_task": "<task>:<short why>" | "none"
    }}
  }},
  "strengths": {{
    "<model_id>": "<one sentence highlighting this model's strongest aspect with a metric>"
  }},
  "verdict": {{
    "use": "<{model_options} | tie | none>",
    "reasons": ["<one sentence citing a metric>", "<one sentence citing a metric>"]
  }}
}}

Rules:
- "metrics" and "strengths" MUST contain one entry per model present in DATA.
- Use the actual model ids from DATA as keys.
- top_defect = the defect axis with the highest score for that model, formatted "<axis>=<num>"; "none" if all axes are zero.
- weak_task = the task where the model dropped most on correctness or shadow, formatted "<task>:<short reason>"; "none" if uniform.
- Pick best correctness + depth + lowest defects. Equal within 10% -> use="tie". One broken (correctness<5 OR severe defect surge) -> pick best of the rest. All broken -> use="none".'''

def call_analyst(aggregates):
    payload = json.dumps(aggregates, indent=2, ensure_ascii=False, default=str)
    model_tags_list = [model_tag(m) for m in models]
    prompt = ANALYST_TEMPLATE.format(
        n_models=len(models),
        n_tasks=len(tasks),
        k=k_runs,
        data=payload[:8000],
        model_options=" | ".join(model_tags_list),
    )
    try:
        proc = subprocess.run(
            ["claude", "--print", prompt,
             "--output-format", "json",
             "--model", judge_model,
             "--tools", "",
             "--no-session-persistence",
             "--max-budget-usd", "0.40"],
            capture_output=True, text=True, timeout=120
        )
        if proc.returncode != 0 or not proc.stdout.strip():
            return None
        raw = json.loads(proc.stdout)
        if isinstance(raw, dict) and raw.get("is_error"):
            return None
        items = raw if isinstance(raw, list) else [raw]
        for item in reversed(items):
            if isinstance(item, dict) and item.get("type") == "result":
                txt = item.get("result", "") or ""
                m = re.search(r'\{.*"verdict".*\}', txt, re.DOTALL)
                if m:
                    try:
                        return json.loads(m.group())
                    except Exception:
                        pass
        return None
    except Exception:
        return None

# ── Load task prompts ─────────────────────────────────────────────────────────
task_prompts = {}
for t in tasks:
    with open(os.path.join(tmpdir, f"{t}.txt")) as f:
        task_prompts[t] = f.read()

# ── Load raw responses ────────────────────────────────────────────────────────
model_tags = [model_tag(m) for m in models]
raw_data = {}
for t in tasks:
    raw_data[t] = {}
    for mt in model_tags:
        raw_data[t][mt] = {}
        for r in range(1, k_runs + 1):
            raw_data[t][mt][r] = load_response(t, mt, r)

# ── Polyrubric phase ──────────────────────────────────────────────────────────
n_judge_calls = sum(
    1 for t in tasks for mt in model_tags for r in range(1, k_runs + 1)
    if not raw_data[t][mt][r]["missing"]
)
print(f"  Sonnet polyrubric ({n_judge_calls} calls)...", flush=True)

judgments = {t: {mt: {} for mt in model_tags} for t in tasks}

def judge_one(t, mt, r):
    resp = raw_data[t][mt][r]
    if resp["missing"]:
        return (t, mt, r, empty_polyrubric("missing response"))
    jud = call_polyrubric(task_prompts[t], resp["text"])
    return (t, mt, r, jud)

with ThreadPoolExecutor(max_workers=8) as pool:
    futures = []
    for t in tasks:
        for mt in model_tags:
            for r in range(1, k_runs + 1):
                futures.append(pool.submit(judge_one, t, mt, r))
    for fut in as_completed(futures):
        t, mt, r, jud = fut.result()
        judgments[t][mt][r] = jud

print(f"  Polyrubric done.", flush=True)

# ── Aggregation ───────────────────────────────────────────────────────────────
agg = {}
for model in models:
    mt = model_tag(model)
    agg[mt] = {}
    for t in tasks:
        runs = []
        for r in range(1, k_runs + 1):
            resp = raw_data[t][mt][r]
            jud  = judgments[t][mt][r]
            if resp["missing"]:
                continue
            visible_tok  = max(1, len(resp["text"]) / 3.5)
            think_proxy  = max(0, resp["output_tokens"] - visible_tok)
            if think_proxy == 0 and resp["thinking_chars"] > 0:
                think_proxy = resp["thinking_chars"] / 3.5
            runs.append({
                "thinking_tokens":  think_proxy,
                "thinking_chars":   resp["thinking_chars"],
                "thinking_hidden":  resp["thinking_hidden"],
                "thinking_blocks":  resp["thinking_blocks"],
                "visible_chars":    resp["visible_chars"],
                "duration_ms":      resp["duration_ms"],
                "correctness_judge":jud["correctness"],
                "depth":            jud["depth"],
                "defects":          {a: jud["defects"][a]["score"] for a in DEFECT_AXES},
                "evidence":         {a: jud["defects"][a]["evidence"] for a in DEFECT_AXES
                                     if jud["defects"][a]["score"] >= 4 and jud["defects"][a]["evidence"]},
                "shadow_correct":   SHADOW[t](resp["text"]) if t in SHADOW else None,
                "cost":             resp["cost"],
            })

        if not runs:
            agg[mt][t] = {
                "thinking_tokens": 0, "thinking_chars": 0,
                "thinking_hidden": False, "thinking_blocks": 0,
                "visible_chars": 0, "duration_ms": 0,
                "correctness_judge": 0, "depth": 0,
                "defects": {a: 0 for a in DEFECT_AXES},
                "shadow_correct_rate": None,
                "cost_sum": 0, "evidence_samples": [],
                "answer": "ERR", "variance": "",
            }
            continue

        m_runs = len(runs)

        # Shadow correct rate
        if t in SHADOW:
            shadow_rate = sum(1 for x in runs if x["shadow_correct"]) / m_runs
        else:
            shadow_rate = None

        # Best answer display
        if t in ("reason", "trace"):
            answers = [first_int(raw_data[t][mt][r]["text"]) for r in range(1, k_runs + 1)
                       if not raw_data[t][mt][r]["missing"]]
            if answers:
                most_common = Counter(a for a in answers if a is not None).most_common(1)
                answer = str(most_common[0][0]) if most_common else "?"
            else:
                answer = "?"
        elif t == "code":
            answer = f"{int(shadow_rate * 100)}%" if shadow_rate is not None else "?"
        elif t == "bugs":
            answer = "ok" if median(x["correctness_judge"] for x in runs) >= 7 else "partial"
        else:
            answer = "ok"

        # Variance
        totals = [x["correctness_judge"] for x in runs]
        if len(set(totals)) > 1:
            spread = max(totals) - min(totals)
            variance = f"±{spread}" if spread > 0 else ""
        else:
            variance = ""

        agg[mt][t] = {
            "thinking_tokens":   median(x["thinking_tokens"]   for x in runs),
            "thinking_chars":    median(x["thinking_chars"]    for x in runs),
            "thinking_hidden":   any(x["thinking_hidden"]      for x in runs),
            "thinking_blocks":   median(x["thinking_blocks"]   for x in runs),
            "visible_chars":     median(x["visible_chars"]     for x in runs),
            "duration_ms":       median(x["duration_ms"]       for x in runs),
            "correctness_judge": median(x["correctness_judge"] for x in runs),
            "depth":             median(x["depth"]             for x in runs),
            "defects":           {a: median(x["defects"][a]    for x in runs) for a in DEFECT_AXES},
            "shadow_correct_rate": shadow_rate,
            "cost_sum":          sum(x["cost"]   for x in runs),
            "evidence_samples":  [x["evidence"]  for x in runs if x["evidence"]],
            "answer":            answer,
            "variance":          variance,
        }

# ── Per-model summary ─────────────────────────────────────────────────────────
per_model = {}
for model in models:
    mt = model_tag(model)
    shadow_tasks = [t for t in tasks if agg[mt][t]["shadow_correct_rate"] is not None]
    per_model[mt] = {
        "mean_thinking_tokens": mean(agg[mt][t]["thinking_tokens"]   for t in tasks),
        "mean_duration_ms":     mean(agg[mt][t]["duration_ms"]       for t in tasks),
        "mean_blocks":          mean(agg[mt][t]["thinking_blocks"]   for t in tasks),
        "mean_depth":           mean(agg[mt][t]["depth"]             for t in tasks),
        "mean_correctness":     mean(agg[mt][t]["correctness_judge"] for t in tasks),
        "defect_means":         {a: mean(agg[mt][t]["defects"][a]    for t in tasks) for a in DEFECT_AXES},
        "total_cost":           sum(agg[mt][t]["cost_sum"]           for t in tasks),
        "shadow_pass_rate":     mean(agg[mt][t]["shadow_correct_rate"] for t in shadow_tasks) if shadow_tasks else 0,
    }

# ── Display helpers ───────────────────────────────────────────────────────────
def verdict_color(corr):
    if corr >= 7.5: return f"{G}{B}SHARP ✅{N}"
    if corr >= 5.0: return f"{Y}{B}MEDIOCRE ⚡{N}"
    if corr >= 3.0: return f"{R}{B}DEGRADED ⚠️{N}"
    return f"{R}{B}LOBOTOMIZED \U0001f480{N}"

def verdict_plain(corr):
    if corr >= 7.5: return "SHARP"
    if corr >= 5.0: return "MEDIOCRE"
    if corr >= 3.0: return "DEGRADED"
    return "LOBOTOMIZED"

def build_block(mt):
    dn        = DISPLAY_NAMES.get(mt, mt)
    task_data = agg[mt]
    mean_corr = per_model[mt]["mean_correctness"]
    mean_depth= per_model[mt]["mean_depth"]
    total_cost= per_model[mt]["total_cost"]
    total_think = sum(agg[mt][t]["thinking_tokens"] for t in tasks)
    total_talk  = sum(agg[mt][t]["visible_chars"]   for t in tasks)
    shadow_rate = per_model[mt]["shadow_pass_rate"]

    L = []
    L.append(f"  {B}{dn}{N}")
    if k_runs > 1:
        L.append(f"  {D}медиана из {k_runs} прогонов{N}")
    L.append("")

    for t in tasks:
        d   = task_data[t]
        lab = LABELS[t]
        corr  = d["correctness_judge"]
        depth = d["depth"]

        # Shadow indicator
        sr = d["shadow_correct_rate"]
        if sr is not None:
            if sr >= 1.0:
                shadow_mk = f"{G}✓{N}"
            elif sr > 0:
                shadow_mk = f"{Y}~{N}"
            else:
                shadow_mk = f"{R}✗{N}"
        else:
            shadow_mk = f"{D}·{N}"

        # Correctness color
        cc = G if corr >= 8 else (Y if corr >= 5 else R)

        # Thinking bar
        tk     = d["thinking_tokens"]
        hidden = d["thinking_hidden"]
        if tk == 0 and not hidden:
            think_bar = f"{R}⊘{N}"
        elif hidden:
            think_bar = f"{Y}◆~{fmt_chars(tk)}{N}"
        elif tk >= 5000:
            think_bar = f"{G}█{fmt_chars(tk)}{N}"
        elif tk >= 2000:
            think_bar = f"{Y}▓{fmt_chars(tk)}{N}"
        else:
            think_bar = f"{R}░{fmt_chars(tk)}{N}"

        # Top defect for this task
        top_def = max(DEFECT_AXES, key=lambda a: d["defects"][a])
        top_val = d["defects"][top_def]
        def_s = f" {heat_color(top_val)}{top_def[:4]}={int(top_val)}{N}" if top_val >= 3 else ""

        var_s = f" {D}{d['variance']}{N}" if d.get("variance") else ""

        L.append(
            f"  {lab:<8s}{shadow_mk} {cc}c={corr:<2g}{N} d={depth:<2g}"
            f"  {think_bar}{def_s}{var_s}"
        )

    L.append("")
    L.append(f"  {'─' * 42}")

    L.append(f"  {B}corr {mean_corr:.1f}{N}/10  depth {mean_depth:.1f}/10  {verdict_color(mean_corr)}")

    shadow_s = f"shadow {shadow_rate*100:.0f}%" if shadow_rate > 0 else ""

    if total_talk > 0 and total_think > 0:
        ratio_s = f"ratio {total_think/total_talk:.1f}x"
    elif total_think == 0:
        ratio_s = f"{R}think=0{N}"
    else:
        ratio_s = "ratio think-only"

    any_hidden  = any(agg[mt][t]["thinking_hidden"] for t in tasks)
    think_label = f"~{fmt_chars(total_think)}" if any_hidden else fmt_chars(total_think)

    L.append(f"  {D}${total_cost:.2f}  │  think {think_label}  talk {fmt_chars(total_talk)}  │  {ratio_s}{N}")
    if shadow_s:
        L.append(f"  {D}{shadow_s}{N}")

    return "\n".join(L), mean_corr

# ── gum helpers ───────────────────────────────────────────────────────────────
def gum_style_box(content, border_fg="240"):
    return subprocess.run(
        ["gum", "style", "--border", "rounded", "--width", "54",
         "--padding", "1 1", "--border-foreground", border_fg],
        input=content, capture_output=True, text=True
    ).stdout.rstrip("\n")

def gum_panel(content, args):
    return subprocess.run(
        ["gum", "style"] + args,
        input=content, capture_output=True, text=True
    ).stdout.rstrip("\n")

def best_border(mt_list, scores):
    if not mt_list:
        return {}
    best = max(scores[mt] for mt in mt_list)
    result = {}
    for mt in mt_list:
        if scores[mt] == best and sum(1 for m in mt_list if scores[m] == best) < len(mt_list):
            result[mt] = "46"
        else:
            result[mt] = "240"
    return result

# ── Render model boxes ────────────────────────────────────────────────────────
blocks = {}; scores = {}
for mt in model_tags:
    blocks[mt], scores[mt] = build_block(mt)

borders  = best_border(model_tags, scores)
n_models = len(model_tags)

if n_models == 1:
    mt = model_tags[0]
    print(gum_style_box(blocks[mt], borders[mt]))
elif n_models == 2:
    left  = gum_style_box(blocks[model_tags[0]], borders[model_tags[0]])
    right = gum_style_box(blocks[model_tags[1]], borders[model_tags[1]])
    print(subprocess.run(
        ["gum", "join", "--horizontal", left, "  ", right],
        capture_output=True, text=True
    ).stdout)
elif n_models >= 3:
    top_tags = model_tags[:2]
    bot_tags = model_tags[2:]
    top_boxes = [gum_style_box(blocks[mt], borders[mt]) for mt in top_tags]
    top_row = subprocess.run(
        ["gum", "join", "--horizontal"] + [top_boxes[0], "  ", top_boxes[1]],
        capture_output=True, text=True
    ).stdout.rstrip("\n")
    if len(bot_tags) == 1:
        bot_row = gum_style_box(blocks[bot_tags[0]], borders[bot_tags[0]])
    else:
        bot_boxes = [gum_style_box(blocks[mt], borders[mt]) for mt in bot_tags]
        bot_row = subprocess.run(
            ["gum", "join", "--horizontal"] + [bot_boxes[0], "  ", bot_boxes[1]],
            capture_output=True, text=True
        ).stdout.rstrip("\n")
    print(subprocess.run(
        ["gum", "join", "--vertical", top_row, bot_row],
        capture_output=True, text=True
    ).stdout)

# ── Verbose tables ────────────────────────────────────────────────────────────
if verbose:
    print(f"\n  {B}Thinking effort (median across {k_runs} runs){N}")
    print(f"  {D}{'-' * 72}{N}")
    header = f"  {'task':<10s}"
    for mt in model_tags:
        header += f"  {mt:>12s}"
    if len(model_tags) == 2:
        header += f"  {'ratio[0]/[1]':>14s}"
    print(header)
    for t in tasks:
        line = f"  {LABELS[t]:<10s}"
        vals = [agg[mt][t]["thinking_tokens"] for mt in model_tags]
        for v in vals:
            line += f"  {int(v):>12d}"
        if len(vals) == 2 and vals[1] > 0:
            ratio = vals[0] / vals[1]
            col = G if 0.7 <= ratio <= 1.3 else (Y if 0.5 <= ratio <= 2.0 else R)
            line += f"  {col}{ratio:>13.2f}x{N}"
        print(line)

    print(f"\n  {B}Duration (ms, median){N}")
    print(f"  {D}{'-' * 72}{N}")
    for t in tasks:
        line = f"  {LABELS[t]:<10s}"
        for mt in model_tags:
            line += f"  {int(agg[mt][t]['duration_ms']):>12d}"
        print(line)

    print(f"\n  {B}Defect profile (mean per axis, 0=clean, 10=severe){N}")
    print(f"  {D}{'-' * 72}{N}")
    hdr = f"  {'defect':<14s}"
    for mt in model_tags: hdr += f"  {mt:>12s}"
    if len(model_tags) == 2:
        hdr += f"  {'delta':>10s}"
    print(hdr)
    for a in DEFECT_AXES:
        line = f"  {a:<14s}"
        vals = [per_model[mt]["defect_means"][a] for mt in model_tags]
        for v in vals:
            c = heat_color(v)
            line += f"  {c}{v:>12.2f}{N}"
        if len(vals) == 2:
            d = vals[0] - vals[1]
            sign = "+" if d > 0 else ""
            col  = D if abs(d) < 0.5 else (R if abs(d) > 2 else Y)
            line += f"  {col}{sign}{d:>9.2f}{N}"
        print(line)

    print(f"\n  {B}Summary{N}")
    print(f"  {D}{'-' * 72}{N}")
    for mt in model_tags:
        pm = per_model[mt]
        print(f"  {B}{mt}{N}")
        print(f"    think_tokens(mean) {pm['mean_thinking_tokens']:>8.0f}  "
              f"duration(ms) {pm['mean_duration_ms']:>7.0f}  "
              f"depth {pm['mean_depth']:>4.1f}/10  "
              f"correct {pm['mean_correctness']:>4.1f}/10")
        print(f"    shadow_pass(rate)  {pm['shadow_pass_rate']*100:>6.0f}%  "
              f"cost ${pm['total_cost']:>5.2f}")

    print(f"\n  {B}Evidence samples (defects with score >= 4){N}")
    print(f"  {D}{'-' * 72}{N}")
    shown = 0
    for mt in model_tags:
        for t in tasks:
            for ev_dict in agg[mt][t]["evidence_samples"]:
                for axis, quote in ev_dict.items():
                    if quote and shown < 12:
                        q = quote.replace("\n", " ")[:80]
                        print(f"  {Y}{axis:<14s}{N} {mt:<10s} {LABELS[t]:<8s}  {D}{q}{N}")
                        shown += 1
    if shown == 0:
        print(f"  {D}(none){N}")

# ── Analyst call ──────────────────────────────────────────────────────────────
analyst_data = {}
for mt in model_tags:
    analyst_data[mt] = {
        "mean_thinking_tokens": per_model[mt]["mean_thinking_tokens"],
        "mean_depth":           per_model[mt]["mean_depth"],
        "mean_correctness":     per_model[mt]["mean_correctness"],
        "shadow_pass_rate":     per_model[mt]["shadow_pass_rate"],
        "defect_means":         per_model[mt]["defect_means"],
    }
    for t in tasks:
        key = f"{mt}:{t}"
        analyst_data[key] = {
            "correctness":       agg[mt][t]["correctness_judge"],
            "depth":             agg[mt][t]["depth"],
            "defects":           agg[mt][t]["defects"],
            "shadow_correct_rate": agg[mt][t]["shadow_correct_rate"],
            "thinking_tokens":   agg[mt][t]["thinking_tokens"],
        }

print(f"\n  Analyst call...", flush=True)
verdict = call_analyst(analyst_data)

# ── Analyst panel renderers ───────────────────────────────────────────────────
def render_metrics_panel(metrics, mt_list):
    if not metrics:
        return None
    lines = [f"  {B}Analyst metrics{N}", ""]
    col_w = 14
    hdr   = f"  {'model':<{col_w}s}  {'think_tok':>9s}  {'depth':>6s}  {'corr':>5s}  {'shadow%':>7s}  {'top_defect':>12s}  {'weak_task'}"
    lines.append(hdr)
    lines.append(f"  {D}{'-' * 76}{N}")
    all_corr   = [metrics.get(mt, {}).get("correctness", 0)     for mt in mt_list]
    all_depth  = [metrics.get(mt, {}).get("depth", 0)           for mt in mt_list]
    all_shadow = [metrics.get(mt, {}).get("shadow_pass_pct", 0) for mt in mt_list]
    for mt in mt_list:
        m = metrics.get(mt, {})
        cc = color_numeric(m.get("correctness", 0), all_corr)    or D
        dc = color_numeric(m.get("depth", 0), all_depth)         or D
        sc = color_numeric(m.get("shadow_pass_pct", 0), all_shadow) or D
        dn   = DISPLAY_NAMES.get(mt, mt)
        line = (
            f"  {rpad(dn, col_w)}"
            f"  {m.get('think_tokens', 0):>9d}"
            f"  {dc}{m.get('depth', 0):>6.1f}{N}"
            f"  {cc}{m.get('correctness', 0):>5.1f}{N}"
            f"  {sc}{m.get('shadow_pass_pct', 0):>7d}{N}"
            f"  {fmt_metric(m.get('top_defect', 'none'), 'str', 12):>12s}"
            f"  {fmt_metric(m.get('weak_task', 'none'), 'str', 24)}"
        )
        lines.append(line)
    content = "\n".join(lines)
    return gum_panel(content, ["--width", "82", "--padding", "1 2", "--margin", "0 0"])

def render_strengths_panel(strengths, mt_list):
    if not strengths:
        return None
    lines = [f"  {B}Model strengths{N}", ""]
    for mt in mt_list:
        s  = strengths.get(mt, "")
        dn = DISPLAY_NAMES.get(mt, mt)
        if s:
            lines.append(f"  {B}{dn:<14s}{N}  {D}{s}{N}")
    content = "\n".join(lines)
    return gum_panel(content, ["--width", "82", "--padding", "1 2", "--margin", "0 0"])

def render_verdict_panel(verd):
    if not verd:
        return None
    use     = verd.get("use", "?")
    reasons = verd.get("reasons", [])
    dn      = DISPLAY_NAMES.get(use, use)
    if use == "tie":
        use_line = f"{Y}{B}▶ TIE{N}"
    elif use == "none":
        use_line = f"{R}{B}▶ NONE{N}"
    else:
        use_line = f"{G}{B}▶ {dn}{N}"
    lines = [f"  {B}Analyst verdict{N}", "", f"  {use_line}", ""]
    for r in reasons:
        lines.append(f"  {D}· {r}{N}")
    content = "\n".join(lines)
    return gum_panel(content, ["--border", "rounded", "--width", "60",
                               "--padding", "1 2", "--border-foreground", "46"])

if verdict:
    metrics   = verdict.get("metrics", {})
    strengths = verdict.get("strengths", {})
    verd      = verdict.get("verdict", {})

    mp = render_metrics_panel(metrics, model_tags)
    sp = render_strengths_panel(strengths, model_tags)
    vp = render_verdict_panel(verd)

    if mp: print(mp)
    if sp: print(sp)
    if vp: print(vp)
else:
    print(f"  {R}Analyst call failed{N}")

# ── Save results ──────────────────────────────────────────────────────────────
save_data = {
    "_meta": {
        "version": 4,
        "date": datetime.now().isoformat(),
        "models": models, "tasks": tasks, "runs": k_runs,
        "judge_model": judge_model,
        "verdict": verdict,
    },
}

for mt in model_tags:
    save_data[mt] = {
        "mean_correctness":     per_model[mt]["mean_correctness"],
        "mean_depth":           per_model[mt]["mean_depth"],
        "mean_thinking_tokens": per_model[mt]["mean_thinking_tokens"],
        "shadow_pass_rate":     per_model[mt]["shadow_pass_rate"],
        "total_cost":           per_model[mt]["total_cost"],
        "verdict":              verdict_plain(per_model[mt]["mean_correctness"]),
    }
    for t in tasks:
        key = f"{mt}:{t}"
        save_data[key] = {
            "thinking_tokens":   agg[mt][t]["thinking_tokens"],
            "thinking_chars":    agg[mt][t]["thinking_chars"],
            "visible_chars":     agg[mt][t]["visible_chars"],
            "correctness":       agg[mt][t]["correctness_judge"],
            "depth":             agg[mt][t]["depth"],
            "shadow_correct_rate": agg[mt][t]["shadow_correct_rate"],
            "defects":           agg[mt][t]["defects"],
        }

result_file = os.path.join(results_dir, f"bench_{date_tag}.json")
with open(result_file, "w") as f:
    json.dump(save_data, f, indent=2)
print(f"\n  {D}Результат: {result_file}{N}")

if save_baseline:
    shutil.copy2(result_file, baseline_file)
    print(f"  {G}⭐ Baseline сохранён: {baseline_file}{N}")

# ── History display ───────────────────────────────────────────────────────────
prev = sorted(glob.glob(os.path.join(results_dir, "bench_*.json")), reverse=True)
if len(prev) >= 2:
    print(f"\n  {D}Последние прогоны:{N}")
    for fp in prev[:5]:
        try:
            with open(fp) as fh:
                d = json.load(fh)
            meta       = d.get("_meta", {})
            version    = meta.get("version", 0)
            date       = meta.get("date", "?")[:10]
            runs_info  = meta.get("runs", 1)
            parts = []
            for mt_key in [k for k in d if k != "_meta" and ":" not in k]:
                v = d[mt_key]
                if isinstance(v, dict):
                    if version >= 4 and "mean_correctness" in v:
                        corr = v.get("mean_correctness", 0)
                        tk   = v.get("mean_thinking_tokens", 0)
                        tk_s = f"{tk/1000:.1f}k" if isinstance(tk, (int, float)) and tk >= 1000 else str(int(tk))
                        parts.append(f"{mt_key}:c={corr:.1f} think={tk_s}")
                    elif "pct" in v:
                        tc   = v.get("thinking_chars", "?")
                        tc_s = f"{tc/1000:.1f}k" if isinstance(tc, (int, float)) and tc >= 1000 else str(tc)
                        dn   = mt_key.replace('opus-', '')
                        parts.append(f"{dn}:{v['pct']}% think={tc_s}")
            if parts:
                runs_s = f" x{runs_info}" if runs_info > 1 else ""
                print(f"    {date}{runs_s}  {' │ '.join(parts)}")
        except Exception:
            pass
    print()

# ── Cleanup raw files ─────────────────────────────────────────────────────────
for model in models:
    mt = model_tag(model)
    for t in tasks:
        for r_idx in range(1, k_runs + 1):
            raw_path = os.path.join(results_dir, f"{t}_{mt}_{date_tag}_r{r_idx}.json")
            try: os.remove(raw_path)
            except OSError: pass
